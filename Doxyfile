PROJECT_NAME           = "Football Laravel"
PROJECT_BRIEF          = "Documentation technique du projet BTS SIO"
PROJECT_NUMBER         = "1.0"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
USE_MDFILE_AS_MAINPAGE = README.md
DOXYFILE_ENCODING      = UTF-8
INPUT_ENCODING         = UTF-8

OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = NO
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = NO

INPUT                  = app routes/web.php database/migrations README.md docs/DOCUMENTATION.md
FILE_PATTERNS          = *.php *.md
RECURSIVE              = YES
EXCLUDE                = vendor node_modules storage bootstrap/cache tests database/factories database/seeders
EXCLUDE_PATTERNS       = */vendor/* */node_modules/* */storage/* */bootstrap/cache/* */tests/* */database/factories/* */database/seeders/*
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
SORT_MEMBER_DOCS       = YES

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
QT_AUTOBRIEF           = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

WARNINGS               = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = NO
QUIET                  = YES
